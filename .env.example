# Copy to .env and fill in values.

# ── Firebase Admin ────────────────────────────────────────────────────────────
# Required for server routes (profile sync, admin analytics insights API, etc.).
# Without this, /admin-worship-panel/analytics falls back to limited client-side data.
# Service account MUST be for project faithconnecthub-a4e6b (not the old music-hub project).
# Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Or paste JSON on one line:
# FIREBASE_SERVICE_ACCOUNT_KEY=

RESEND_API_KEY=re_2FqsZKQH_FgtKXxHmGySnTQB7nuzTztjc

# ── Firebase Client — FaithConnectHub (faithconnecthub-a4e6b) ────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=faithconnecthub-a4e6b.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=faithconnecthub-a4e6b
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=faithconnecthub-a4e6b.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
FIREBASE_STORAGE_BUCKET=faithconnecthub-a4e6b.firebasestorage.app

# ── Multi-Church (Tenant) ───────────────────────────────────────────────────
# Set to your primary church document ID after creating the first church.
# Legacy content without churchId is attributed to this ID during reads.
# DEFAULT_CHURCH_ID=
# NEXT_PUBLIC_DEFAULT_CHURCH_ID=

# ── Analytics (optional) ──────────────────────────────────────────────────────
# UMAMI_WEBSITE_ID=

# ── Payments (Donations) ────────────────────────────────────────────────────
# PAYMENT_PROVIDER=stripe
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
# ── Email (Resend) ───────────────────────────────────────────────────────────
# Put your real key only in .env (never commit it).
# RESEND_API_KEY=re_xxxxxxxx
#
# FROM address — must be verified in Resend (see note below).
# Local testing with onboarding@resend.dev:
#   - Emails can ONLY be delivered to the email on your Resend account.
#   - Set ADMIN_NOTIFICATION_EMAIL to that same address while testing.
# RESEND_FROM_EMAIL=FaithConnectHub <onboarding@resend.dev>
#
# REPLY_TO can be any valid inbox (does not affect Resend delivery rules):
# RESEND_REPLY_TO=you@example.com
# ADMIN_NOTIFICATION_EMAIL=you@example.com
#
# Must include protocol for correct email links:
# NEXT_PUBLIC_APP_URL=http://localhost:3000