# Copy to .env and fill in values.

# ── Firebase Admin ────────────────────────────────────────────────────────────
# Service account MUST be for project faithconnecthub-a4e6b (not the old music-hub project).
# Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Or paste JSON on one line:
# FIREBASE_SERVICE_ACCOUNT_KEY=

# ── Firebase Client — FaithConnectHub (faithconnecthub-a4e6b) ────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=faithconnecthub-a4e6b.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=faithconnecthub-a4e6b
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=faithconnecthub-a4e6b.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
FIREBASE_STORAGE_BUCKET=faithconnecthub-a4e6b.firebasestorage.app

# ── Multi-Church (Tenant) ───────────────────────────────────────────────────
# Set to your primary church document ID after creating the first church.
# Legacy content without churchId is attributed to this ID during reads.
# DEFAULT_CHURCH_ID=
# NEXT_PUBLIC_DEFAULT_CHURCH_ID=

# ── Analytics (optional) ──────────────────────────────────────────────────────
# UMAMI_WEBSITE_ID=

# ── Payments (Donations) ────────────────────────────────────────────────────
# PAYMENT_PROVIDER=stripe
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
