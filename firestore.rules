rules_version = '2';

// Deploy: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userDocExists() {
      return isSignedIn() && exists(userDocPath());
    }

    function userData() {
      return get(userDocPath()).data;
    }

    function isPlatformSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "futureblock07@gmail.com" ||
        (userDocExists() && userData().role == "admin")
      );
    }

    function isChurchAdminFor(churchId) {
      return userDocExists() && (
        (userData().churchRole == "admin" && userData().churchId == churchId) ||
        (userData().managedChurchIds is list && churchId in userData().managedChurchIds)
      );
    }

    function canManageChurchContent(churchId) {
      return isPlatformSuperAdmin() || isChurchAdminFor(churchId);
    }

    function hasValidChurchId() {
      return request.resource.data.churchId is string
        && request.resource.data.churchId.size() > 0;
    }

    /** Legacy single-tenant installs may use a shared default church id. */
    function isLegacyDefaultChurchId(churchId) {
      return churchId == "default" || churchId == "faithconnecthub";
    }

    function churchIdUnchanged() {
      return request.resource.data.churchId == resource.data.churchId;
    }

    function isValidUserSelfUpdate() {
      return request.resource.data.role == resource.data.role
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "firstName",
          "lastName",
          "email",
          "emailPreferences",
          "updatedAt",
          "churchId",
          "churchRole",
          "managedChurchIds"
        ]);
    }

    function isValidPrayerRequestCreate() {
      return request.resource.data.keys().hasAll([
        "churchId",
        "userId",
        "name",
        "title",
        "request",
        "isAnonymous",
        "status",
        "prayerCount",
        "createdAt",
        "updatedAt"
      ])
        && request.resource.data.churchId is string
        && (hasValidChurchId() || isLegacyDefaultChurchId(request.resource.data.churchId))
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.title is string
        && request.resource.data.request is string
        && request.resource.data.isAnonymous is bool
        && request.resource.data.status == "pending"
        && request.resource.data.prayerCount == 0
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 100
        && request.resource.data.request.size() > 0
        && request.resource.data.request.size() <= 1000
        && (!('category' in request.resource.data)
          || request.resource.data.category is string)
        && (!('shareWithCommunity' in request.resource.data)
          || request.resource.data.shareWithCommunity is bool)
        && (!('isAnswered' in request.resource.data)
          || request.resource.data.isAnswered == false);
    }

    function isPrayerRequestOwnerAnswered() {
      return isSignedIn()
        && resource.data.userId == request.auth.uid
        && resource.data.isAnswered != true
        && request.resource.data.isAnswered == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "isAnswered",
          "answeredAt",
          "updatedAt"
        ]);
    }

    function isValidPrayerIntercessionCreate(intercessionId) {
      return isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.requestId is string
        && request.resource.data.requestId.size() > 0
        && request.resource.data.keys().hasAll([
          "requestId",
          "userId",
          "createdAt"
        ])
        && intercessionId == request.resource.data.requestId + '_' + request.auth.uid;
    }

    function currentPrayerCount() {
      return resource.data.prayerCount is int
        ? resource.data.prayerCount
        : (resource.data.prayerCount is float
          ? int(resource.data.prayerCount)
          : 0);
    }

    function isPrayerCountIncrement() {
      return isSignedIn()
        && resource.data.status == "approved"
        && request.resource.data.status == "approved"
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "prayerCount",
          "updatedAt"
        ])
        && request.resource.data.prayerCount is int
        && request.resource.data.prayerCount == currentPrayerCount() + 1;
    }

    function isPrayerCountDecrement() {
      return isSignedIn()
        && resource.data.status == "approved"
        && request.resource.data.status == "approved"
        && currentPrayerCount() > 0
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "prayerCount",
          "updatedAt"
        ])
        && request.resource.data.prayerCount == currentPrayerCount() - 1;
    }

    function isSongPlayCountIncrement() {
      return isSignedIn()
        && churchIdUnchanged()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["playCount"])
        && request.resource.data.playCount
          == (resource.data.playCount is int ? resource.data.playCount + 1 : 1);
    }

    match /churches/{churchId} {
      allow read: if resource.data.isActive == true || isPlatformSuperAdmin();
      allow create, update, delete: if isPlatformSuperAdmin();
    }

    match /songs/{songId} {
      allow read: if true;
      allow create: if canManageChurchContent(request.resource.data.churchId) && hasValidChurchId();
      allow update: if (canManageChurchContent(resource.data.churchId) && churchIdUnchanged())
        || isSongPlayCountIncrement();
      allow delete: if canManageChurchContent(resource.data.churchId);
    }

    match /sermons/{sermonId} {
      allow read: if true;
      allow create: if canManageChurchContent(request.resource.data.churchId) && hasValidChurchId();
      allow update: if canManageChurchContent(resource.data.churchId) && churchIdUnchanged();
      allow delete: if canManageChurchContent(resource.data.churchId);
    }

    match /ceremonies/{sermonId} {
      allow read: if true;
      allow create: if canManageChurchContent(request.resource.data.churchId) && hasValidChurchId();
      allow update: if canManageChurchContent(resource.data.churchId) && churchIdUnchanged();
      allow delete: if canManageChurchContent(resource.data.churchId);
    }

    match /articles/{articleId} {
      allow read: if true;
      allow create: if canManageChurchContent(request.resource.data.churchId) && hasValidChurchId();
      allow update: if canManageChurchContent(resource.data.churchId) && churchIdUnchanged();
      allow delete: if canManageChurchContent(resource.data.churchId);
    }

    match /events/{eventId} {
      allow read: if resource.data.status == "published" || isPlatformSuperAdmin() || isChurchAdminFor(resource.data.churchId);
      allow create: if canManageChurchContent(request.resource.data.churchId) && hasValidChurchId();
      allow update: if canManageChurchContent(resource.data.churchId) && churchIdUnchanged();
      allow delete: if canManageChurchContent(resource.data.churchId);
    }

    match /eventRegistrations/{registrationId} {
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow create: if false;
      allow update, delete: if false;
    }

    match /donationCampaigns/{campaignId} {
      allow read: if isPlatformSuperAdmin()
        || isChurchAdminFor(resource.data.churchId)
        || resource.data.status == "active";
      allow create: if canManageChurchContent(request.resource.data.churchId) && hasValidChurchId();
      allow update: if canManageChurchContent(resource.data.churchId) && churchIdUnchanged();
      allow delete: if canManageChurchContent(resource.data.churchId);
    }

    match /donations/{donationId} {
      allow read: if isPlatformSuperAdmin()
        || isChurchAdminFor(resource.data.churchId)
        || (isSignedIn()
          && request.auth.token.email != null
          && resource.data.donorEmail == request.auth.token.email);
      allow create, update, delete: if false;
    }

    match /recentlyViewed/{recentlyViewedId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid
        || isPlatformSuperAdmin();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.itemId is string
        && request.resource.data.itemId.size() > 0
        && request.resource.data.itemType in ["song", "sermon", "article"]
        && request.resource.data.keys().hasAll([
          "userId",
          "itemId",
          "itemType",
          "viewedAt"
        ]);
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.itemId == resource.data.itemId
        && request.resource.data.itemType == resource.data.itemType
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["viewedAt"]);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /prayerRequests/{requestId} {
      allow read: if resource.data.status == "approved"
        || isPlatformSuperAdmin()
        || isChurchAdminFor(resource.data.churchId)
        || (isSignedIn() && resource.data.userId == request.auth.uid)
        || (isSignedIn()
          && request.auth.token.email != null
          && resource.data.email == request.auth.token.email);
      allow create: if isSignedIn() && isValidPrayerRequestCreate();
      allow update: if isPlatformSuperAdmin()
        || isChurchAdminFor(resource.data.churchId)
        || isPrayerCountIncrement()
        || isPrayerCountDecrement()
        || isPrayerRequestOwnerAnswered();
      allow delete: if isPlatformSuperAdmin() || isChurchAdminFor(resource.data.churchId);
    }

    match /prayerIntercessions/{intercessionId} {
      allow read: if isSignedIn() && (
        resource == null
        || resource.data.userId == request.auth.uid
        || isPlatformSuperAdmin()
      );
      allow create: if isValidPrayerIntercessionCreate(intercessionId);
      allow update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /favorites/{favoriteId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid
        || isPlatformSuperAdmin();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.itemId is string
        && request.resource.data.itemId.size() > 0
        && request.resource.data.itemType in ["song", "sermon", "article"]
        && request.resource.data.keys().hasAll([
          "userId",
          "itemId",
          "itemType",
          "createdAt"
        ]);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    match /users/{userId}/notificationReads/{readId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId
        || isPlatformSuperAdmin()
        || (userDocExists()
          && resource.data.churchId is string
          && isChurchAdminFor(resource.data.churchId));
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.role == "user";
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && isValidUserSelfUpdate();
    }

    match /subscriptions/{churchId} {
      allow read: if isPlatformSuperAdmin()
        || isChurchAdminFor(churchId)
        || (userDocExists() && userData().churchId == churchId);
      allow create, update, delete: if isPlatformSuperAdmin();
    }
  }
}
